{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Adazella project Claude Code settings. Hooks, permissions, env vars for the project.",

  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run dev:*)",
      "Bash(node -e:*)",
      "Bash(node -c:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin main)",
      "Bash(npx tsc:*)",
      "Bash(pip install:*)",
      "Bash(python -m:*)",
      "Bash(bash .claude/hooks/*)",
      "Bash(bash .claude/skills/*/scripts/*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push --no-verify:*)",
      "Bash(sudo:*)",
      "WebFetch(domain:*.bank.com)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/subagent-stop.sh"
          }
        ]
      }
    ]
  },

  "env": {
    "_comment": "Project-scoped env vars Claude can use. Secrets go in OS env vars, NOT here.",
    "PROJECT_NAME": "Adazella",
    "DEFAULT_REGION": "ap-south-1"
  }
}
