# ========================================
# AdPilot root env template
# Copy this to .env in each app that needs it
# ========================================

# ---- Supabase (shared) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...                # public key, for client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...        # server-only, never expose

# ---- Database ----
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ---- Amazon Ads OAuth (per-user, filled via flow) ----
AMAZON_ADS_CLIENT_ID=amzn1.application-oa2-client.xxxxx
AMAZON_ADS_CLIENT_SECRET=xxxxx
AMAZON_ADS_REDIRECT_URI=http://localhost:5173/oauth/amazon/callback

# ---- Stripe (commercial) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxx
FROM_EMAIL=hello@adpilot.app

# ---- App URLs ----
FRONTEND_URL=http://localhost:5173
MARKETING_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---- API ----
PORT=4000
NODE_ENV=development
JWT_SECRET=generate-a-random-32-char-string

# ---- Sentry (errors) ----
SENTRY_DSN=
