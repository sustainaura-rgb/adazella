{
  "name": "adpilot",
  "version": "0.1.0",
  "private": true,
  "description": "AdPilot — Amazon Ads automation platform for sellers",
  "workspaces": [
    "frontend",
    "api",
    "marketing",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:frontend": "npm run dev -w frontend",
    "dev:api": "npm run dev -w api",
    "dev:marketing": "npm run dev -w marketing",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
