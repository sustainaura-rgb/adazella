# Scheduler env
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Amazon Ads OAuth (shared app credentials — each user has their own refresh_token in DB)
AMAZON_ADS_CLIENT_ID=amzn1.application-oa2-client.xxxxx
AMAZON_ADS_CLIENT_SECRET=xxxxx

# Health check port (for Render/Railway free tier)
PORT=10000
